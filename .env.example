# ─── Frontend ────────────────────────────────────────────────
# API base URL consumed by Next.js (public = exposed to browser)
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── Backend ─────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true

# ─── AI / Transcription (optional — mock mode used if not set) ────────────────
# Deepgram Nova-2 for speaker-diarized transcription
DEEPGRAM_API_KEY=

# OpenAI GPT-4o for SOAP note generation
OPENAI_API_KEY=
