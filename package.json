{
  "name": "dori-ai",
  "version": "0.1.0",
  "private": true,
  "description": "Dori.ai — clinical documentation assistant monorepo",
  "scripts": {
    "dev": "concurrently \"bun run dev:frontend\" \"bun run dev:backend\"",
    "dev:frontend": "cd frontend && bun dev",
    "dev:backend": "cd backend && uvicorn app.main:app --reload --port 8000"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
